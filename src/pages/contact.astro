---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data";
---
<BaseLayout title="Contact Ian | VCUK Web Services" description="Contact Ian at VCUK Web Services by email, WhatsApp, phone, or contact form to ask about websites, redesigns, SEO foundations, or website care.">
<section class="page-hero"><div class="container"><span class="eyebrow">Contact</span><h1>Tell Ian what your website needs to do better.</h1><p class="lead">You do not need a perfect brief. Send your current website, Facebook page, or rough idea and Ian will suggest the most sensible next step.</p></div></section>
<section class="section"><div class="container split"><div><span class="eyebrow">Start simple</span><h2>A rough message is enough.</h2><ul class="features"><li>Your current website or social page.</li><li>What you do and where you work.</li><li>What feels unclear, dated, or difficult right now.</li><li>Whether you need a new site, redesign, SEO foundations, or support.</li></ul><p><strong>Email:</strong> <a href={`mailto:${site.email}`}>{site.email}</a></p><p><strong>WhatsApp / phone:</strong> <a href={site.whatsappUrl}>{site.phoneVisible}</a></p></div><form class="form-shell" id="contact-form" novalidate><div class="form-grid"><div class="field"><label for="name">Name</label><input id="name" name="name" required /></div><div class="field"><label for="business_name_contact">Business name</label><input id="business_name_contact" name="business_name" required /></div><div class="field"><label for="email">Email</label><input id="email" name="email" type="email" required /></div><div class="field"><label for="website_or_social">Website or social page</label><input id="website_or_social" name="website_or_social" /></div><div class="field full"><label for="message">What do you need help with?</label><textarea id="message" name="message" required></textarea></div><div class="honeypot"><label for="company_website_contact">Company website</label><input id="company_website_contact" name="company_website" tabindex="-1" /></div></div><button class="button" type="submit" style="margin-top:1rem">Send message to Ian</button><p class="status" id="contact-status" hidden></p></form></div></section>
</BaseLayout>
<script is:inline>
const form=document.getElementById('contact-form');const status=document.getElementById('contact-status');form?.addEventListener('submit',async e=>{e.preventDefault();if(!form.reportValidity())return;status.hidden=false;status.textContent='Sending...';try{const r=await fetch('/api/contact',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(Object.fromEntries(new FormData(form)))});const data=await r.json();if(!r.ok)throw new Error(data.message||'Something went wrong.');form.reset();status.textContent='Thanks. Your message has been sent to Ian.';}catch(err){status.textContent=err.message||'Something went wrong.';}});
</script>
