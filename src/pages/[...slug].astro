---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site, services, workItems, guides } from "../data";

const paths = [
  { slug: undefined, kind: "home", title: "VCUK Web Services | Clear Websites for Local Businesses", description: "VCUK Web Services builds fast, polished websites for small UK service businesses, with clear pricing, practical SEO foundations, and direct support from Ian." },
  { slug: "services", kind: "services", title: "Website Services for Small Businesses | VCUK Web Services", description: "Explore VCUK website services including one-page websites, starter websites, business websites, redesigns, SEO foundations, local SEO support, and care plans." },
  { slug: "pricing", kind: "pricing", title: "Website Pricing | VCUK Web Services", description: "Transparent starting prices for one-page websites, starter websites, business websites, redesigns, SEO foundations, and monthly website support." },
  { slug: "work", kind: "work", title: "Work and Website Examples | VCUK Web Services", description: "See real VCUK work and clearly labelled concept website examples for local service businesses including pet care, trades, cleaning, and beauty." },
  { slug: "guides", kind: "guides", title: "Small Business Website Guides | VCUK Web Services", description: "Plain-English guides from VCUK on one-page websites, Facebook vs websites, trust signals, SEO basics, and clearer enquiry journeys." },
  { slug: "about", kind: "about", title: "About VCUK Web Services | Direct With Ian", description: "Learn why VCUK Web Services exists, how Ian works with small service businesses, and what makes the approach practical, honest, and clear." },
  { slug: "contact", kind: "contact", title: "Contact Ian | VCUK Web Services", description: "Contact Ian at VCUK Web Services by email, WhatsApp, phone, or contact form to ask about websites, redesigns, SEO foundations, or website care." },
  ...services.map((s) => ({ slug: `services/${s.slug}`, kind: "service", item: s, title: `${s.short} | VCUK Web Services`, description: s.summary })),
  ...guides.map((g) => ({ slug: `guides/${g.slug}`, kind: "guide", item: g, title: `${g.title} | VCUK Guides`, description: g.summary }))
];
export function getStaticPaths() { return paths.map((p) => ({ params: { slug: p.slug }, props: { page: p } })); }
const { page } = Astro.props;
const service = page.item;
const guide = page.item;
const serviceFaqs = service?.faqs || [];
---
<BaseLayout title={page.title} description={page.description}>
{page.kind === "home" && <>
  <section class="hero"><div class="container hero-grid"><div><span class="eyebrow">Websites from £350 · Direct with Ian</span><h1><span class="blue">Clearer websites</span> for local businesses that need more enquiries, not more confusion.</h1><p class="lead">VCUK Web Services builds fast, polished websites for small UK service businesses. Clear services, stronger trust, better mobile experience, and simple routes for customers to call, message, book, or request a quote.</p><div class="button-row"><a class="button" href="/contact/">Get a website quote</a><a class="button secondary" href="/work/">See what VCUK can build</a></div><div class="trust"><span class="pill">Websites from £350</span><span class="pill">Based in Winsford, Cheshire</span><span class="pill">Direct with Ian</span><span class="pill">Mobile-first and SEO-aware</span></div></div><div class="mockup" aria-label="Example service business website mockup"><div class="mockup-bar"><span class="dot"></span><span class="dot"></span><span class="dot"></span></div><div class="mockup-screen"><span class="pill">Trusted local service</span><div class="preview-grid"><div><p class="preview-title">Clear services, proof, and quick quote routes.</p><span class="line" style="width:86%"></span><span class="line" style="width:72%"></span></div><div class="preview-art"></div></div><div class="grid grid-3"><div class="card"><strong>Services explained</strong></div><div class="card"><strong>Reviews and proof</strong></div><div class="card"><strong>Call or WhatsApp</strong></div></div></div></div></div></section>
  <section class="section"><div class="container split"><div><span class="eyebrow">The real problem</span><h2>Your business may already have the proof. The problem is where customers have to find it.</h2></div><div><p class="lead">Many small businesses have strong photos, reviews, services, and contact details scattered across Facebook, Instagram, messages, and old web pages. VCUK turns that into one clear website customers can understand quickly.</p><ul class="features"><li>No making customers scroll through posts to find prices or services.</li><li>No unclear first impression when someone searches your business name.</li><li>No missed enquiries because the next step is buried.</li><li>No website that looks cheaper than the work you actually do.</li></ul></div></div></section>
  <ServiceGrid />
  <Why />
  <WorkGrid limit={2} />
  <Checker />
  <Process />
  <GuideGrid />
  <CTA />
</>}

{page.kind === "services" && <><PageHero eyebrow="Services" h="Website services built around clarity, trust, and enquiries." text="VCUK helps small service businesses turn scattered information into clear websites with sensible pricing, useful structure, and direct support from Ian." /><ServiceGrid all /><section class="section frost"><div class="container split"><div><span class="eyebrow">How to choose</span><h2>The right option depends on how much customers need to understand before they enquire.</h2></div><ul class="features"><li>Choose a one-page website when you need a sharp first home online.</li><li>Choose a starter or business website when services need their own pages.</li><li>Choose a redesign when the existing site undersells the business.</li><li>Choose care or SEO support when the foundations are ready to improve.</li></ul></div></section><CTA /></>}

{page.kind === "pricing" && <><PageHero eyebrow="Pricing" h="Clear starting prices before you book a call." text="Prices are practical starting points, not vague bait. The final quote depends on pages, content, integrations, proof assets, and support needs." /><section class="section"><div class="container grid grid-3">{services.map((s) => <article class="card"><p class="price">{s.price}</p><h2 style="font-size:1.55rem">{s.short}</h2><p>{s.summary}</p><a href={`/services/${s.slug}/`}>What this includes</a></article>)}</div></section><section class="section frost"><div class="container split"><div><span class="eyebrow">What affects price</span><h2>A focused £350 site is not the same job as a full business website.</h2></div><ul class="features"><li>Number of pages and service detail.</li><li>How much copy, proof, or old content needs sorting.</li><li>Forms, booking links, redirects, and technical cleanup.</li><li>SEO foundations, guide structure, and local wording.</li><li>Ongoing updates or support after launch.</li></ul></div></section><CTA /></>}

{page.kind === "work" && <><PageHero eyebrow="Work" h="Proof first, concepts labelled clearly." text="VCUK shows real client work where accurate and uses concept examples honestly to demonstrate structure, design thinking, and commercial clarity." /><WorkGrid /><CTA /></>}

{page.kind === "guides" && <><PageHero eyebrow="Guides" h="Plain-English website advice for small businesses." text="Short, practical guides Ian can point people to when they are deciding what their website should do next." /><GuideGrid all /><CTA /></>}

{page.kind === "about" && <><PageHero eyebrow="About" h="A practical web service for businesses that need clarity before complexity." text="VCUK exists to help small businesses look as clear, trusted, and easy to contact online as they often already are in real life." /><section class="section"><div class="container split"><div><span class="eyebrow">Direct with Ian</span><h2>No agency maze. No confusing tech talk.</h2><p>VCUK is intentionally focused. Ian works directly with small service businesses to plan and build websites that explain the offer, show trust, and make the next step obvious.</p><p>The aim is to understand how your customers choose, what proof they need, and what contact route makes sense on mobile.</p></div><div class="card"><span class="pill">VCUK working notes</span><h3>What should the website make clearer?</h3><ul class="features"><li>What do you do?</li><li>Where do you work?</li><li>Why should customers trust you?</li><li>How can they enquire quickly?</li></ul></div></div></section><CTA /></>}

{page.kind === "contact" && <><PageHero eyebrow="Contact" h="Tell Ian what your website needs to do better." text="You do not need a perfect brief. Send your current website, Facebook page, or rough idea and Ian will suggest the most sensible next step." /><section class="section"><div class="container split"><div><span class="eyebrow">Start simple</span><h2>A rough message is enough.</h2><ul class="features"><li>Your current website or social page.</li><li>What you do and where you work.</li><li>What feels unclear, dated, or difficult right now.</li><li>Whether you need a new site, redesign, SEO foundations, or support.</li></ul><p><strong>Email:</strong> <a href={`mailto:${site.email}`}>{site.email}</a></p><p><strong>WhatsApp / phone:</strong> <a href={site.whatsappUrl}>{site.phoneVisible}</a></p></div><ContactForm /></div></section></>}

{page.kind === "service" && <><section class="page-hero"><div class="container"><span class="eyebrow">{service.price}</span><h1>{service.title}</h1><p class="lead">{service.summary}</p><div class="button-row"><a class="button" href="/contact/">Ask Ian about this</a><a class="button secondary" href="/pricing/">Compare pricing</a></div></div></section><section class="section"><div class="container split"><article><span class="eyebrow">Who it is for</span><h2>Best suited to businesses that need a practical next step.</h2><p>{service.bestFor}</p></article><article class="card"><span class="eyebrow">Problem it solves</span><h2 style="font-size:1.8rem">{service.problem}</h2></article></div></section><section class="section frost"><div class="container split"><div><span class="eyebrow">What is included</span><h2>Clear scope before build.</h2><p class="lead">Every project is agreed before work starts, so you know what is included and what can wait.</p></div><ul class="features">{service.includes.map((i) => <li>{i}</li>)}</ul></div></section><section class="section"><div class="container"><div class="section-head"><span class="eyebrow">FAQs</span><h2>Useful questions before you enquire.</h2></div><div class="grid grid-3">{serviceFaqs.map(([q,a]) => <details class="card"><summary><strong>{q}</strong></summary><p>{a}</p></details>)}</div></div></section><section class="section frost"><div class="container card"><h2>Helpful next pages</h2><p>Compare pricing, see honest work examples, read guides, or contact Ian with your current website.</p><div class="button-row"><a class="button secondary" href="/pricing/">Pricing</a><a class="button secondary" href="/work/">Work</a><a class="button secondary" href="/guides/">Guides</a><a class="button" href="/contact/">Contact Ian</a></div></div></section><CTA /></>}

{page.kind === "guide" && <><article><section class="page-hero"><div class="container"><span class="eyebrow">{guide.category} · {guide.reading}</span><h1>{guide.title}</h1><p class="lead">{guide.summary}</p></div></section><section class="section"><div class="container" style="max-width:820px">{guide.body.map((p) => <p>{p}</p>)}<h2>A practical next step</h2><p>If your website has useful proof but no clear structure, start with the <a href="/#website-checker">website checker</a> or ask Ian which service fits.</p></div></section></article><CTA /></>}
</BaseLayout>

<!-- Components -->
{false && <div />}

<script></script>

---
const PageHero = ({ eyebrow, h, text }) => <section class="page-hero"><div class="container"><span class="eyebrow">{eyebrow}</span><h1>{h}</h1><p class="lead">{text}</p><div class="button-row"><a class="button" href="/contact/">Contact Ian</a><a class="button secondary" href="/pricing/">View pricing</a></div></div></section>;
const ServiceGrid = ({ all = false }) => <section class="section frost"><div class="container"><div class="section-head"><span class="eyebrow">Services</span><h2>Practical website packages with a clear starting point.</h2><p class="lead">Start focused, then grow the site when there is a real commercial reason.</p></div><div class={`grid ${all ? "grid-3" : "grid-4"}`}>{services.slice(0, all ? services.length : 4).map((s) => <article class="card"><p class="price">{s.price}</p><h3><a href={`/services/${s.slug}/`}>{s.short}</a></h3><p>{s.summary}</p><a href={`/services/${s.slug}/`}>View service details</a></article>)}</div></div></section>;
const Why = () => <section class="section band"><div class="container split"><div><span class="eyebrow">Why VCUK</span><h2>A smaller web service with sharper focus.</h2><p>VCUK is not trying to be a big digital agency. You work directly with Ian to plan a website that makes sense for your business, your customers, and your budget.</p></div><ul class="features"><li>Direct communication with the person building the site.</li><li>Clear scope before build, with honest recommendations.</li><li>Practical SEO foundations without ranking promises.</li><li>Mobile-first pages designed around how customers choose.</li></ul></div></section>;
const WorkGrid = ({ limit }) => <section class="section"><div class="container"><div class="section-head"><span class="eyebrow">Work and examples</span><h2>Built to show the standard before you enquire.</h2><p class="lead">Real work is labelled clearly. Concept builds are shown honestly as examples.</p></div><div class="grid grid-2">{workItems.slice(0, limit || workItems.length).map(([title,label,summary]) => <article class="browser"><div class="visual"><span class="pill">{label}</span><h3>{title}</h3><div class="visual-box"></div></div><div class="card"><h3>{title}</h3><p>{summary}</p></div></article>)}</div></div></section>;
const GuideGrid = ({ all = false }) => <section class="section frost"><div class="container"><div class="section-head"><span class="eyebrow">Guides</span><h2>Plain-English website advice for small businesses.</h2></div><div class="grid grid-3">{guides.slice(0, all ? guides.length : 3).map((g) => <article class="card"><span class="pill">{g.category} · {g.reading}</span><h3><a href={`/guides/${g.slug}/`}>{g.title}</a></h3><p>{g.summary}</p><a href={`/guides/${g.slug}/`}>Read the guide</a></article>)}</div></div></section>;
const Process = () => <section class="section"><div class="container"><div class="section-head"><span class="eyebrow">Process</span><h2>A simple process from messy idea to launched website.</h2></div><div class="grid grid-4">{["Review", "Structure", "Design and build", "Launch and improve"].map((s,i) => <article class="card"><span class="pill">Step {i+1}</span><h3>{s}</h3><p>{["Business, current presence, services, customers, competitors, and enquiry goals.","Pages, sections, proof, calls to action, SEO priorities, and practical scope.","Mobile-first design, fast pages, clear copy, forms, contact links, and test-ready layout.","Launch checks, Search Console where needed, handover, and optional support."][i]}</p></article>)}</div></div></section>;
const CTA = () => <section class="section"><div class="container"><div class="cta"><div><h2>Tell Ian what your website needs to do better.</h2><p>Send your current website, Facebook page, or rough idea. You do not need a perfect brief; a plain message is enough to start.</p></div><div class="button-row"><a class="button" href="/contact/">Start the conversation</a><a class="button secondary" href={site.whatsappUrl}>WhatsApp Ian</a></div></div></div></section>;
const ContactForm = () => <form class="form-shell" id="contact-form" novalidate><div class="form-grid"><div class="field"><label for="name">Name</label><input id="name" name="name" required /></div><div class="field"><label for="business_name_contact">Business name</label><input id="business_name_contact" name="business_name" required /></div><div class="field"><label for="email">Email</label><input id="email" name="email" type="email" required /></div><div class="field"><label for="website_or_social">Website or social page</label><input id="website_or_social" name="website_or_social" /></div><div class="field full"><label for="message">What do you need help with?</label><textarea id="message" name="message" required></textarea></div><div class="honeypot"><label for="company_website_contact">Company website</label><input id="company_website_contact" name="company_website" tabindex="-1" /></div></div><button class="button" type="submit" style="margin-top:1rem">Send message to Ian</button><p class="status" id="contact-status" hidden></p></form>;
const Checker = () => <section class="section frost" id="website-checker"><div class="container split"><div><span class="eyebrow">Free website clarity check</span><h2>Quick check: is your website making enquiries easier?</h2><p class="lead">Enter your website and a few business details. The checker runs a practical rule-based review, shows your score, and emails you the result. Ian also receives a copy.</p><ul class="features"><li>Checks services, area wording, contact routes, trust signals, structure, SEO basics, and mobile warning signs.</li><li>If the website cannot be fetched, you still get a helpful partial result.</li><li>No fake AI claims. It is a useful first-pass clarity check.</li></ul></div><form class="form-shell" id="checker-form" novalidate><div class="form-grid"><div class="field full"><label for="website_url">Website URL</label><input id="website_url" name="website_url" required /></div><div class="field"><label for="business_name">Business name</label><input id="business_name" name="business_name" required /></div><div class="field"><label for="checker_email">Email address</label><input id="checker_email" name="email" type="email" required /></div><div class="field full"><label for="business_description">Short business description</label><textarea id="business_description" name="business_description" required></textarea></div><div class="honeypot"><label for="company_website">Company website</label><input id="company_website" name="company_website" tabindex="-1" /></div></div><button class="button" type="submit" style="margin-top:1rem">Check my website</button><p class="status" id="checker-status" hidden></p><div class="result" id="checker-result" hidden></div></form></div></section>;
---
<script is:inline>
function wireForm(id, endpoint, statusId, resultId){const form=document.getElementById(id);const status=document.getElementById(statusId);const result=resultId&&document.getElementById(resultId);form?.addEventListener('submit',async e=>{e.preventDefault();if(!form.reportValidity())return;status.hidden=false;status.textContent='Sending...';if(result)result.hidden=true;try{const r=await fetch(endpoint,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(Object.fromEntries(new FormData(form)))});const data=await r.json();if(!r.ok)throw new Error(data.message||'Something went wrong.');if(result){result.innerHTML=`<div class="score" style="--score:${data.score}%"><span>${data.score}</span></div><h3>${data.headline}</h3><p>${data.summary}</p><h4>Strengths</h4><ul>${data.strengths.map(x=>`<li>${x}</li>`).join('')}</ul><h4>Gaps</h4><ul>${data.gaps.map(x=>`<li>${x}</li>`).join('')}</ul><h4>Next steps</h4><ul>${data.nextSteps.map(x=>`<li>${x}</li>`).join('')}</ul><p><a class="button" href="/contact/">Ask Ian about this result</a></p>`;result.hidden=false;}status.textContent='Done. A copy has been emailed where email is configured.';if(id==='contact-form')form.reset();}catch(err){status.textContent=err.message||'Something went wrong.';}})}
wireForm('contact-form','/api/contact','contact-status');wireForm('checker-form','/api/checker','checker-status','checker-result');
</script>
